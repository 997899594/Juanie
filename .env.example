# ============================================
# 数据库 (PostgreSQL)
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=juanie
DATABASE_USER=postgres
DATABASE_PASSWORD=your-database-password
DATABASE_SSL_MODE=disable

# ============================================
# 认证配置 (NextAuth.js)
# ============================================
NEXTAUTH_SECRET=your-secret-key-at-least-32-characters
NEXTAUTH_URL=http://localhost:3000

# ============================================
# OAuth 配置
# ============================================
# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# GitLab OAuth (可选)
# GITLAB_CLIENT_ID=your-gitlab-client-id
# GITLAB_CLIENT_SECRET=your-gitlab-client-secret
# GITLAB_BASE_URL=https://gitlab.com

# ============================================
# Redis 配置 (BullMQ 队列)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# ============================================
# Kubernetes 配置
# ============================================
KUBECONFIG=~/.kube/config
# 或者直接使用内容
# KUBECONFIG_CONTENT=<base64-encoded-kubeconfig>

# ============================================
# 平台配置
# ============================================
NODE_ENV=development
PLATFORM_API_URL=http://localhost:3001
JUANIE_BASE_DOMAIN=juanie.art
JUANIE_ARGOCD_NAMESPACE=argocd
JUANIE_ARGOCD_PROJECT=juanie
JUANIE_ARGOCD_DESTINATION_SERVER=https://kubernetes.default.svc
JUANIE_PREVIEW_APPLICATIONSET_ENABLED=true
JUANIE_PREVIEW_APPLICATIONSET_REPO_URL=https://github.com/997899594/Juanie.git
JUANIE_PREVIEW_APPLICATIONSET_TARGET_REVISION=main
JUANIE_PREVIEW_APPLICATIONSET_PATH=deploy/k8s/charts/preview-scaffold
DEPLOY_REGISTRY=ghcr.io
DEPLOY_REGISTRY_PULL_SECRET_NAME=ghcr-pull-secret
# DEPLOY_REGISTRY_USERNAME=
# DEPLOY_REGISTRY_PASSWORD=

# ============================================
# 历史保留 / 清理
# ============================================
ENABLE_HISTORY_RETENTION=true
HISTORY_RETENTION_SCHEDULE=17 */6 * * *
DEPLOYMENT_LOG_RETENTION_DAYS=14
AUDIT_LOG_RETENTION_DAYS=30
AI_PLUGIN_RUN_RETENTION_DAYS=14
AI_PLUGIN_SNAPSHOT_RETENTION_DAYS=30
MIGRATION_RUN_RETENTION_DAYS=30
SCHEMA_REPAIR_ATLAS_RUN_RETENTION_DAYS=30

# ============================================
# AI 配置 (302.ai)
# ============================================
AI_ENABLED=false
AI_302_API_KEY=
AI_302_BASE_URL=https://api.302.ai/v1
AI_DEFAULT_PLAN=free
AI_MODEL=gemini-2.5-flash
AI_MODEL_PRO=gemini-2.5-pro
AI_MODEL_TOOL=gemini-2.5-flash
